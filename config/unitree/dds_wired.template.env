# Unitree G1 wired DDS template for the v0.2 read-only stage.
# Copy this file to your local machine and edit values there.
# Do not commit machine-specific IPs or secrets.

# Example wired NIC from current lab machine notes.
export G1_WIRED_IFACE="enp6s0"

# Optional: set this before running scripts/real_g1_network_readonly_check.sh
# export G1_IP="192.168.xxx.xxx"

# ROS 2 domain. Use the value required by your Unitree / lab DDS setup.
# export ROS_DOMAIN_ID=42

# Keep this unset unless your DDS setup explicitly needs it.
# export CYCLONEDDS_URI="file:///path/to/cyclonedds.xml"

# Read-only recording topics. Replace with actual topic names discovered via `ros2 topic list`.
export TOPICS="/g1/lidar_points /g1/imu /g1/odom /tf /tf_static"
